**/target/
!**/.mvn/wrapper/maven-wrapper.jar

# ─── IntelliJ IDEA ───────────────────────────────
.idea/
**/*.iml
**/*.iws
**/*.ipr

# ─── VS Code ─────────────────────────────────────
.vscode/

